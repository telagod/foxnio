# FoxNIO 环境配置

# 服务配置
APP_NAME=FoxNIO
APP_ENV=development
APP_PORT=3000

# 数据库配置
DATABASE_URL=postgres://foxnio:foxnio_secret@localhost:5432/foxnio
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_HOURS=168

# 网关配置
GATEWAY_API_KEY_PREFIX=foxnio
GATEWAY_RATE_MULTIPLIER=1.0

# 日志配置
RUST_LOG=info,foxnio=debug
RUST_BACKTRACE=1

# OAuth 配置 (可选)
ANTHROPIC_CLIENT_ID=
ANTHROPIC_CLIENT_SECRET=
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=
GEMINI_CLIENT_ID=
GEMINI_CLIENT_SECRET=

# 备份配置
BACKUP_DIR=/var/backups/foxnio
BACKUP_RETENTION_DAYS=30
