# FoxNIO 环境配置

# 服务配置
APP_NAME=FoxNIO
APP_ENV=development
APP_PORT=3000
FOXNIO_SERVER_HOST=0.0.0.0
FOXNIO_SERVER_PORT=8080

# 数据库配置
DATABASE_URL=postgres://foxnio:foxnio_secret@localhost:5432/foxnio
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_HOURS=168
FOXNIO_MASTER_KEY=

# 网关配置
GATEWAY_API_KEY_PREFIX=foxnio
GATEWAY_RATE_MULTIPLIER=1.0
DROID_BASE_URL=http://127.0.0.1:3000

# 前端构建配置
VITE_API_URL=http://localhost:8080

# 日志配置
RUST_LOG=info,foxnio=debug
RUST_BACKTRACE=1

# OAuth 配置 (可选)
ANTHROPIC_CLIENT_ID=
ANTHROPIC_CLIENT_SECRET=
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=
GEMINI_CLIENT_ID=
GEMINI_CLIENT_SECRET=

# 备份配置
BACKUP_DIR=/var/backups/foxnio
BACKUP_RETENTION_DAYS=30

# 支付配置
FOXNIO_BASE_URL=http://localhost:8080

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=cny

# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# 微信支付
WXPAY_APP_ID=
WXPAY_MCH_ID=
WXPAY_API_KEY=
WXPAY_NOTIFY_URL=

# EasyPay
EASYPAY_MERCHANT_ID=
EASYPAY_API_KEY=
EASYPAY_NOTIFY_URL=
